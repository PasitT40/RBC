{
  "functions": [
    {
      "source": "functions/public-api",
      "codebase": "public-api"
    }
  ],
  "firestore": [
    {
      "database": "ratchaburi-camera-dev",
      "rules": "firestore.rules",
      "indexes": "firestore.indexes.json"
    },
    {
      "database": "ratchaburi-camera-prod",
      "rules": "firestore.rules",
      "indexes": "firestore.indexes.json"
    }
  ],
  "storage": [
    {
      "target": "dev",
      "rules": "storage.rules"
    },
    {
      "target": "prod",
      "rules": "storage.rules"
    }
  ],
  "hosting": [
    {
      "target": "backoffice",
      "public": ".output/public",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "/api/**",
          "function": {
            "functionId": "publicApi",
            "region": "asia-southeast1"
          }
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "target": "backoffice-prod",
      "public": ".output/public",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "/api/**",
          "function": {
            "functionId": "publicApi",
            "region": "asia-southeast1"
          }
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ]
}
