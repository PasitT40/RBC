{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": [
    {
      "target": "dev",
      "rules": "storage.rules"
    },
    {
      "target": "prod",
      "rules": "storage.rules"
    }
  ],
  "hosting": [
    {
      "target": "backoffice",
      "public": ".output/public",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ]
}
