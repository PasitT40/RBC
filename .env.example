# Single environment Firebase configuration
NUXT_PUBLIC_FIREBASE_API_KEY=
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NUXT_PUBLIC_FIREBASE_PROJECT_ID=
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET_PROD=
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET_DEV=
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NUXT_PUBLIC_FIREBASE_APP_ID=
NUXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
# Storage bucket selection policy:
# - Firestore "ratchaburi-camera-prod" => `gs://ratchaburi-camera-prod`
# - Firestore "ratchaburi-camera-dev" => `gs://ratchaburi-camera-dev`
# Keep NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET as a backward-compatible fallback for any other database id.
# Storage Rules authorize writes with Firebase Auth custom claim `backoffice_owner=true`.
# After granting or revoking that claim, force a fresh sign-in before testing uploads.
NUXT_PUBLIC_FIRESTORE_DATABASE_ID=
FIRESTORE_DATABASE_ID=
SERVICE_ACCOUNT_KEY_FILE=serviceAccountKey.dev.json
