[
  {
    "origin": ["*"],
    "method": ["GET", "HEAD", "PUT", "PATCH", "POST", "DELETE"],
    "responseHeader": [
      "Content-Type", 
      "Authorization", 
      "Content-Length", 
      "User-Agent", 
      "x-goog-resumable", 
      "x-goog-upload-command", 
      "x-goog-upload-protocol"
    ],
    "maxAgeSeconds": 3600
  }
]
